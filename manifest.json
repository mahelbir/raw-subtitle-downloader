{
  "manifest_version": 3,
  "name": "Raw Subtitle Downloader",
  "version": "2.0.1",
  "description": "Detect and download subtitle files from any website while you browse",
  "permissions": [
    "webRequest",
    "downloads"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "32": "images/icon32.png",
      "128": "images/icon128.png",
      "192": "images/icon192.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "128": "images/icon128.png",
    "192": "images/icon192.png"
  }
}